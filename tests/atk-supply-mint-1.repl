;; ATK-SUPPLY-MINT-1: re-mint tras init.
;; Superficie: init-supply y init tras init ya hecho por setup.repl.
;; Mutaciones: doble init-supply (chain 0), init en chain !=0 despues, init-supply en otra chain.
(load "setup.repl")

;; Supply total actual (cap-table): 55000+10000+15000+20000 = 100000
(begin-tx "M1: supply base")
(print (format "treasury={} founder={} liquidity={} ipo={}"
  [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TREASURY-ACCOUNT)
   (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.FUNDERS-ACCOUNT)
   (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.LIQUIDITY-ACCOUNT)
   (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-ACCOUNT)]))
(commit-tx)

;; (1) Doble init-supply como admin en chain 0 => enforce-not-initialized debe rechazar
(begin-tx "M1a: doble init-supply admin chain0")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-01T00:00:00Z") })
(env-data
  { "founder-ks":       { "keys": ["f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0"], "pred": "keys-all" }
  , "treasury-ops-ks":  { "keys": ["a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1"], "pred": "keys-all" }
  , "liquidity-ops-ks": { "keys": ["b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2"], "pred": "keys-all" } })
(env-keys ["admin-key"])
(expect-failure "module already initialized"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.init-supply
    n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-ACCOUNT n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-G
    "k:f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0" (read-keyset 'founder-ks)
    "k:a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1" (read-keyset 'treasury-ops-ks)
    "k:b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2" (read-keyset 'liquidity-ops-ks)))
(commit-tx)

;; (2) init (no-supply) en chain 0 tras init-supply => enforce !=0 rechaza (Use init-supply)
(begin-tx "M1b: init en chain0 tras init-supply")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-01T00:00:00Z") })
(env-keys ["admin-key"])
(expect-failure "init en chain0 rechazado"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.init "ipo-x"))
(commit-tx)

;; (3) init en chain 1 tras init-supply => enforce-not-initialized (state ya existe) debe rechazar
;;     (state es singleton STATE-KEY; init-supply ya lo insertó => insert duplicate O bien not-initialized)
(begin-tx "M1c: init en chain 1 con state ya inicializado")
(env-chain-data { "chain-id": "1", "block-time": (time "2026-06-01T00:00:00Z") })
(env-keys ["admin-key"])
(expect-failure "init chain1 rechazado (ya inicializado)"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.init "ipo-x"))
(commit-tx)

;; (4) init-supply en chain 1 => enforce chain 0 rechaza
(begin-tx "M1d: init-supply en chain 1")
(env-chain-data { "chain-id": "1", "block-time": (time "2026-06-01T00:00:00Z") })
(env-data
  { "founder-ks":       { "keys": ["f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0"], "pred": "keys-all" }
  , "treasury-ops-ks":  { "keys": ["a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1"], "pred": "keys-all" }
  , "liquidity-ops-ks": { "keys": ["b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2"], "pred": "keys-all" } })
(env-keys ["admin-key"])
(expect-failure "Supply init only on chain 0"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.init-supply
    n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-ACCOUNT n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-G
    "k:f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0f0" (read-keyset 'founder-ks)
    "k:a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1a1" (read-keyset 'treasury-ops-ks)
    "k:b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2b2" (read-keyset 'liquidity-ops-ks)))
(commit-tx)

;; supply sin cambios
(begin-tx "M1: supply final invariante")
(expect "treasury 55000 intacto" 55000.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TREASURY-ACCOUNT))
(expect "ipo 20000 intacto" 20000.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.IPO-RESERVE-ACCOUNT))
(commit-tx)
(print "ATK-SUPPLY-MINT-1 done")
