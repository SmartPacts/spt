(load "setup.repl")
;; ATAQUE 4: inflar reported hasta 20 (chains 0..19) via el defpact xchain,
;; para forzar complete=true y passed=true. En el harness (BD compartida) el
;; tally se recuenta; el objetivo es ver si el CONTRATO permite llegar a passed=true
;; SIN que las 20 chains reales hayan reportado su propio tally.
(begin-tx "activate IPO + seed alice 4500")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.init 0.5)
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.resume-sale)
(commit-tx)
(begin-tx "seed alice 4500")
(env-data { "alice": { "keys": ["alice-key"], "pred": "keys-all" } })
(env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" "alice" 2250.0)] }])
(coin.transfer-create "sender00" "alice" (read-keyset 'alice) 2250.0)
(env-sigs [{ "key": "alice-key", "caps": [(coin.TRANSFER "alice" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.income-account) 2250.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.buy-shares "alice" (read-keyset 'alice) 4500.0)
(commit-tx)
(begin-tx "open P + vote yes 4500")
(env-keys ["admin-key"])
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-02T00:00:00Z") })
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.create-proposal "P" "t" "d" (time "2026-06-02T00:00:00Z") 259200)
(commit-tx)
(begin-tx "alice votes")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-03T00:00:00Z") })
(env-keys ["alice-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.cast-vote "alice" "P" true)
(commit-tx)
(begin-tx "report hub chain 0")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-06T00:00:00Z") })
(env-keys ["atk-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.report-tally-hub "P")
(commit-tx)

;; chains 1..19 via defpact
(begin-tx "xchain chains 1..19")
(env-keys ["atk-key"])
(map (lambda (c:integer)
  (let ((cs (int-to-str 10 c)))
    (env-chain-data { "chain-id": cs, "block-time": (time "2026-06-06T00:00:00Z") })
    (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.report-tally-xchain "P")
    (env-chain-data { "chain-id": "0", "block-time": (time "2026-06-06T00:00:00Z") })
    (continue-pact 1)))
  (enumerate 1 19))
(let ((f (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-final-results "P")))
  (print (format "FINAL after 20 reports: {}" [f]))
  (print (format "reported={} complete={} passed={}"
    [(at 'chains-reported f) (at 'complete f) (at 'passed f)])))
(commit-tx)
(print "ATK4 done")
