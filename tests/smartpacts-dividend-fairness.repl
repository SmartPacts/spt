(begin-tx "DF-11 after the stranded drain: identity exact, only dust owed")
(env-data { "all-accts": ["alice" "bob" "carol" "dave" "bob-a" "bob-b" "erin" "frank" "grace"] })
(let ((l (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (sum-pend (fold (+) 0.0
                  (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a))
                       (read-msg 'all-accts)))))
  (expect "liability == Σ pending EXACT after the stranded drain" sum-pend l)
  ;; COMPOSITION property (5th pass): per-account dust is each < 1e-12 (unclaimable),
  ;; but Σ dust across the 9 accounts crossed the 12-dp threshold — the AGGREGATE
  ;; stays counted in L (conservation: nothing silently vanishes), so floor12(L) is
  ;; one dust quantum, not 0, and the chain is deliberately still "fundable".
  (expect "aggregate dust crossed 1e-12 and stays counted in L" 0.000000000001 (floor l 12))
  (expect "pool still covers the aggregate-dust liability" true
    (>= (coin.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.POOL-ACCOUNT) (floor l 12))))
(commit-tx)
