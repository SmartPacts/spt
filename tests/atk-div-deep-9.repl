;; V9 -- EFFECTIVE-AT = AHORA EXACTO (== block-time). Frontera <=: debe accruar.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V9 effective-at == now exacto")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "Rnow" 0.02 (time "2026-06-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts))))
      (rps (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (print (format "V9 ORACULO: O1={} On={} rps={}" [o1 on rps]))
  (expect "V9 O1==On" on o1)
  (expect "V9 frontera == now es efectiva (<=)" 0.02 rps)
  (expect "V9 L == 100" 100.0 o1))
(commit-tx)
(print "V9 FIN")
