;; V12 -- FUNDING floor(L) - 1 quantum (infrafondeo por 1e-12). DEBE rebotar.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V12 R1 0.02, fund floor(L)-1e-12")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(let* ((liab (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
       (fl (floor liab 12))
       (under (- fl 0.000000000001)))
  ;; llevamos revenue exacto y probamos fund con 1 quantum de menos
  (env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.REVENUE-ACCOUNT fl)] }])
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.receive-revenue "sender00" fl)
  (env-keys ["admin-key"])
  (print (format "V12: L={} floor={} under={}" [liab fl under]))
  (expect-failure "V12 infrafondeo por 1 quantum rebota" "pool underfunded"
    (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.fund-dividends under)))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V12 ORACULO: O1={} On={}" [o1 on]))
  (expect "V12 O1==On" on o1))
(commit-tx)
(print "V12 FIN")
