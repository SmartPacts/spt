;; ATK vote-double 7 (borde temporal exacto / off-by-one): close-at = 2026-06-05T00:00:00Z.
;; (a) A vota. En t == close-at EXACTO, A transfiere: proposal-active? usa (< now close) => false,
;;     asi que release NO fira (congelado). Pero cast-vote usa (< now close) => tampoco vota.
;; (b) Un microsegundo ANTES de close-at: release SI debe firar. Verifico la frontera limpia.
;; Hipotesis: en el instante limite, transferir libera pero votar no (o viceversa), dejando
;; weight colgado que un tercero pueda re-votar => doble. O part>circ en la frontera.
(load "setup.repl")
(begin-tx "activate IPO")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.init 0.5)
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.resume-sale)
(commit-tx)
(begin-tx "seed alice 3000 bob 2000")
(env-data { "alice": { "keys": ["alice-key"], "pred": "keys-all" }
          , "bob":   { "keys": ["bob-key"],   "pred": "keys-all" } })
(env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" "alice" 1500.0) (coin.TRANSFER "sender00" "bob" 1000.0)] }])
(coin.transfer-create "sender00" "alice" (read-keyset 'alice) 1500.0)
(coin.transfer-create "sender00" "bob"   (read-keyset 'bob)   1000.0)
(env-sigs [{ "key": "alice-key", "caps": [(coin.TRANSFER "alice" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.income-account) 1500.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.buy-shares "alice" (read-keyset 'alice) 3000.0)
(env-sigs [{ "key": "bob-key", "caps": [(coin.TRANSFER "bob" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.income-account) 1000.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-ipo.buy-shares "bob" (read-keyset 'bob) 2000.0)
(commit-tx)
(begin-tx "open P: created 2026-06-02, dur 259200 -> close-at 2026-06-05T00:00:00Z")
(env-keys ["admin-key"])
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-02T00:00:00Z") })
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.create-proposal "P" "t" "d" (time "2026-06-02T00:00:00Z") 259200)
(commit-tx)
(begin-tx "alice votes YES 3000")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-03T00:00:00Z") })
(env-keys ["alice-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.cast-vote "alice" "P" true)
(commit-tx)
;; --- (a) EXACT close-at instant ---
(begin-tx "at EXACT close-at: alice transfers 1000 to bob")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-05T00:00:00Z") })
(env-sigs [{ "key": "alice-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "alice" "bob" 1000.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer "alice" "bob" 1000.0)
(let ((r (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-results "P")))
  (print (format "at close-at exact: yes={} aliceW={} aliceBal={} (release fired? weight<3000)"
    [(at 'yes r) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.vote-weight "alice" "0" "P")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance "alice")])))
(commit-tx)
(begin-tx "at EXACT close-at: bob tries to vote his new shares -> expect closed")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-05T00:00:00Z") })
(env-keys ["bob-key"])
(expect-failure "vote at exact close-at is closed" "voting closed"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.cast-vote "bob" "P" true))
(commit-tx)
(begin-tx "consistency: whatever happened, part<=circ AND weight<=balance at the boundary")
(let ((r (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-results "P"))
      (circ (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-circulating)))
  (print (format "boundary check: yes={} part={} circ={} part<=circ={} aliceW<=aliceBal={}"
    [(at 'yes r) (at 'participation r) circ (<= (at 'participation r) circ)
     (<= (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.vote-weight "alice" "0" "P")
         (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-balance "alice"))])))
(commit-tx)
;; --- (b) one microsecond BEFORE close-at: release MUST fire cleanly ---
(begin-tx "1us BEFORE close-at on a fresh proposal Q: alice votes then transfers, release fires")
(env-keys ["admin-key"])
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-02T00:00:00Z") })
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.create-proposal "Q" "t" "d" (time "2026-06-02T00:00:00Z") 259200)
(commit-tx)
(begin-tx "alice votes Q (she has 2000 now)")
(env-chain-data { "chain-id": "0", "block-time": (time "2026-06-04T23:59:59Z") })
(env-keys ["alice-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.cast-vote "alice" "Q" true)
(env-sigs [{ "key": "alice-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "alice" "bob" 500.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer "alice" "bob" 500.0)
(let ((r (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-results "Q"))
      (circ (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-circulating)))
  (print (format "Q just-before-close: yes={} aliceW={} part<=circ={} (release should have fired: weight~1500)"
    [(at 'yes r) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.vote-weight "alice" "0" "Q") (<= (at 'participation r) circ)])))
(commit-tx)
