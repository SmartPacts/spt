;; V19 — RONDA CON FLOAT = 0. Sin seed: circ=0. declare no mueve KDA; L=0; fund rechaza (dead chain).
(load "setup.repl")
(env-data { "accts": [] })
(begin-tx "V19 declara ronda con float 0")
(env-keys ["admin-key"])
(expect "V19 circ es 0" 0.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-circulating))
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (rps (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (print (format "V19 ORACULO O1={} rps={} circ=0" [o1 rps]))
  (expect "V19 rps sube a 0.02" 0.02 rps)
  (expect "V19 L == 0 (no hay float)" 0.0 o1))
(env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.REVENUE-ACCOUNT 10.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.receive-revenue "sender00" 10.0)
(env-keys ["admin-key"])
(expect-failure "V19 fund dead chain (circ=0 L=0) rechazado" "nothing fundable"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.fund-dividends 10.0))
(commit-tx)
(print "V19 FIN")
