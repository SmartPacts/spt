;; V8 — EFFECTIVE-AT en el PASADO (antes del block-time 2026-06-01). Debe accruar ya.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V8 effective-at pasado")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "Rpast" 0.02 (time "2020-01-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts))))
      (rps (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (print (format "V8 ORACULO: O1={} On={} rps={}" [o1 on rps]))
  (expect "V8 O1==On" on o1)
  (expect "V8 ronda pasada ya efectiva -> rps 0.02" 0.02 rps)
  (expect "V8 L == 100" 100.0 o1))
(commit-tx)
(print "V8 FIN")
