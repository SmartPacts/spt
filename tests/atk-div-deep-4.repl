;; V4 — RATE = 1e-12 (mínimo quantum). circ 5000 -> L = 5000*1e-12 = 5e-9. Oráculo exacto.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V4 rate 1e-12")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "Rq" 0.000000000001 (time "2026-06-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V4 ORACULO: O1={} On={} rps={}" [o1 on (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)]))
  (expect "V4 O1==On" on o1)
  (expect "V4 L == 5000*1e-12 = 5e-9" 0.000000005 o1))
(commit-tx)
(print "V4 FIN")
