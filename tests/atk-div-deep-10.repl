;; V10 — EFFECTIVE-AT FUTURO. rps NO debe moverse hasta que pase el tiempo; luego sí, UNA vez.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V10 declara ronda futura")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "Rfut" 0.03 (time "2027-01-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts))))
      (rps (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (print (format "V10a (antes) ORACULO: O1={} On={} rps={}" [o1 on rps]))
  (expect "V10a O1==On" on o1)
  (expect "V10a ronda futura NO accrua todavia -> rps 0, L 0" 0.0 o1))
(commit-tx)
(begin-tx "V10 avanza el reloj al futuro")
(env-chain-data { "chain-id": "0", "block-time": (time "2027-06-01T00:00:00Z") })
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts))))
      (rps (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (print (format "V10b (despues) ORACULO: O1={} On={} rps={}" [o1 on rps]))
  (expect "V10b O1==On" on o1)
  (expect "V10b ronda futura ya efectiva -> rps 0.03" 0.03 rps)
  (expect "V10b L == 5000*0.03 = 150" 150.0 o1))
(commit-tx)
(print "V10 FIN")
