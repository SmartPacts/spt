;; V6 — RATE con 13 DECIMALES (viola enforce-unit -> rechazo esperado).
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V6 rate 13 decimales")
(env-keys ["admin-key"])
(expect-failure "V6 rate 13dp rechazado (enforce-unit)" "amount violates minimum precision"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R13" 0.0000000000001 (time "2026-06-01T00:00:00Z")))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V6 ORACULO: O1={} On={}" [o1 on]))
  (expect "V6 O1==On" on o1))
(commit-tx)
(print "V6 FIN")
