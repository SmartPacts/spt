;; ATK-UPGRADE-5: re-migrar un chain YA migrado con estado AVANZADO.
;; Angulo nuevo: tras migrar (round-count n=0), declaro+aplico rondas (round-count sube, rps sube,
;; rounds-applied sube). Vuelvo a llamar migrate-adr015 varias veces. Si NO es idempotente,
;; podria: (a) re-zerar rounds-applied -> re-aplicar rondas ya aplicadas -> DOBLE PAGO de dividendos,
;; o (b) re-insertar round-count. Debe ser "already migrated" sin tocar NADA.
(env-chain-data { "chain-id": "1", "block-time": (time "2026-06-01T00:00:00Z") })

(begin-tx "load coin")
(load "fixtures/fungible-v2.pact")
(load "fixtures/fungible-xchain-v1.pact")
(load "fixtures/gas-payer-v1.pact")
(load "fixtures/coin.pact")
(create-table coin.coin-table)
(create-table coin.allocation-table)
(commit-tx)

(begin-tx "fund sender00")
(env-data { "sender00": { "keys": ["admin-key"], "pred": "keys-all" } })
(test-capability (coin.COINBASE))
(coin.coinbase "sender00" (read-keyset "sender00") 1000000.0)
(commit-tx)

(begin-tx "deploy PRE-module fresh + init chain 1")
(env-data
  { "ns": "n_d97ffd2ca290429b5dc85ce551a8d07d038e9641"
  , "spt-admin-name": "n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.spt-admin"
  , "spt-admin": { "keys": ["admin-key"], "pred": "keys-all" }
  , "upgrade": false })
(env-keys ["admin-key"])
(define-namespace "n_d97ffd2ca290429b5dc85ce551a8d07d038e9641" (read-keyset 'spt-admin) (read-keyset 'spt-admin))
(load "fixtures/pre-adr015-shares.pact")
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.init "k:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
(commit-tx)

(begin-tx "UPGRADE + first migrate (heals)")
(env-data
  { "ns": "n_d97ffd2ca290429b5dc85ce551a8d07d038e9641"
  , "spt-admin-name": "n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.spt-admin"
  , "spt-admin": { "keys": ["admin-key"], "pred": "keys-all" }
  , "upgrade": true })
(env-keys ["admin-key"])
(load "../contracts/testnet06/smartpacts-shares.pact")
(create-table n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-rounds)
(create-table n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.round-count)
(expect "first migrate heals" "migrated" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.migrate-adr015))
(commit-tx)

;; declare + apply TWO rounds -> round-count=2, rounds-applied=2, rps=0.05
(begin-tx "declare + apply two rounds")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R2" 0.03 (time "2026-06-01T00:00:00Z"))
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.apply-round "all")
(print (format "rps after 2 rounds: {}" [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)]))
(print (format "round-count: {}" [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-round-count)]))
(commit-tx)

;; --- ATAQUE: re-migrar sobre estado avanzado, 3 veces seguidas ---
(begin-tx "ATTACK 5: re-migrate an advanced chain (must NOT reset rounds-applied)")
(env-keys ["admin-key"])
(let ((rps-b (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps))
      (rc-b (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-round-count)))
  (expect "re-migrate 1 is no-op" "already migrated" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.migrate-adr015))
  (expect "re-migrate 2 is no-op" "already migrated" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.migrate-adr015))
  (expect "re-migrate 3 is no-op" "already migrated" (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.migrate-adr015))
  (expect "rps UNCHANGED after 3 re-migrations" rps-b (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps))
  (expect "round-count UNCHANGED" rc-b (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-round-count)))
(commit-tx)

;; verificar que apply-round tras las re-migraciones NO re-aplica (no double-count)
(begin-tx "apply-round after re-migrate must be a no-op (rounds already applied)")
(expect-failure "no newly-effective rounds -> apply-round rejects (no double pay)"
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.apply-round "again"))
(commit-tx)
(print "ATK-UPGRADE-5 done")
