;; V13 — SOBREFONDEO (fund de mas). Debe pasar; el exceso queda en pool, L no cambia; solvencia holgada.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V13 R1 0.02, sobrefondeo 500 (L=100)")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.REVENUE-ACCOUNT 500.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.receive-revenue "sender00" 500.0)
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.fund-dividends 500.0)
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts))))
      (pool (coin.get-balance n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.POOL-ACCOUNT)))
  (print (format "V13 ORACULO: O1={} On={} pool={}" [o1 on pool]))
  (expect "V13 O1==On" on o1)
  (expect "V13 L sigue 100 (sobrefondeo no cambia lo debido)" 100.0 o1)
  (expect "V13 pool=500 holgado > L" true (> pool o1)))
;; el sobrefondeo NO debe ser reclamable por holders (solo devengado); alice cobra su 60, no mas.
(env-data { "alice": { "keys": ["alice-key"], "pred": "keys-all" }, "accts": ["alice" "bob"] })
(let ((paid (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.claim-dividends "alice")))
  (print (format "V13 alice cobro {}" [paid]))
  (expect "V13 alice cobra 3000*0.02=60, NO el exceso" 60.0 paid))
(commit-tx)
(print "V13 FIN")
