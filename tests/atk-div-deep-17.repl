;; V17 — CLAIM PARCIAL + CHURN. alice cobra su devengado, luego mueve shares, luego 2a ronda.
;; No debe re-cobrar la 1a ronda ni perder la 2a. Oráculo O1==On tras cada paso.
;; (L es ACUMULATIVA: incluye el R1 no cobrado de bob + la R2 completa sobre el circulante.)
(load "setup.repl")
(load "seed-div.repl")
(env-data { "carol": {"keys":["ck"],"pred":"keys-all"}, "accts": ["alice" "bob" "carol"] })
(begin-tx "V17 R1 0.02 + fund + alice claim")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(env-sigs [{ "key": "admin-key", "caps": [(coin.TRANSFER "sender00" n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.REVENUE-ACCOUNT 100.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.receive-revenue "sender00" 100.0)
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.fund-dividends 100.0)
(let ((paid (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.claim-dividends "alice")))
  (print (format "V17 alice cobro {}" [paid]))
  (expect "V17 alice cobra 60" 60.0 paid))
(commit-tx)
(begin-tx "V17 alice->carol 1000 tras cobrar")
(env-sigs [{ "key": "alice-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "alice" "carol" 1000.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer-create "alice" "carol" (read-keyset 'carol) 1000.0)
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V17 tras churn ORACULO: O1={} On={}" [o1 on]))
  (expect "V17 O1==On tras claim+churn" on o1)
  (expect "V17 carol pending 0 (llega a rps global)" 0.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "carol"))
  (expect "V17 alice no re-cobra R1 (pending 0)" 0.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "alice"))
  (expect "V17 L tras churn == bob R1 no cobrado = 40" 40.0 o1))
(commit-tx)
(begin-tx "V17 R2 0.01 -> reparto justo, L acumulativa")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R2" 0.01 (time "2026-06-01T00:00:00Z"))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V17 R2 ORACULO: O1={} On={} carol={} alice={} bob={}"
    [o1 on (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "carol")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "alice")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "bob")]))
  (expect "V17 R2 O1==On" on o1)
  ;; L = bob R1(40) + R2 sobre circ 5000 (50) = 90 ; carol 1000*0.01=10, alice 2000*0.01=20, bob 40+20=60
  (expect "V17 R2 L == 40 (R1 bob) + 50 (R2 circ) = 90 (sin doble-pago)" 90.0 o1)
  (expect "V17 carol gana 1000*0.01=10 en R2" 10.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "carol")))
(commit-tx)
(print "V17 FIN")
