;; V18 — ORDEN DE OPERACIONES. Dos secuencias que deben dar el MISMO total devengado.
;; Path A declarar-mover ; Path B mover-declarar. El total owed = circ*rps = 100 en ambos.
;; Ademas sub-aditividad agresiva con dust puro (saldo 1e-6, rate 7e-7 -> owed 7e-13, floor 0).
(load "setup.repl")
(load "seed-div.repl")
(env-data { "x": {"keys":["xk"],"pred":"keys-all"}, "y": {"keys":["yk"],"pred":"keys-all"}
          , "accts": ["alice" "bob" "x" "y"] })
(begin-tx "V18 Path B: alice->y 1500 ANTES de ronda")
(env-sigs [{ "key": "alice-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "alice" "y" 1500.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer-create "alice" "y" (read-keyset 'y) 1500.0)
(commit-tx)
(begin-tx "V18 declara R1 0.02")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(commit-tx)
(begin-tx "V18 Path A: alice->x 1500 DESPUES de ronda")
(env-sigs [{ "key": "alice-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "alice" "x" 1500.0)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer-create "alice" "x" (read-keyset 'x) 1500.0)
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V18 ORACULO: O1={} On={}" [o1 on]))
  (print (format "V18 reparto alice={} y={} x={} bob={}"
    [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "alice")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "y")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "x")
     (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "bob")]))
  (expect "V18 O1==On" on o1)
  (expect "V18 total owed == circ*rps == 100 (independiente del orden)" 100.0 o1)
  (expect "V18 x pending 0 (movio-despues)" 0.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "x"))
  (expect "V18 y pending 30 (presente en la ronda)" 30.0 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "y")))
(commit-tx)
(begin-tx "V18 sub-aditividad dust puro")
(env-data { "m": {"keys":["mk"],"pred":"keys-all"} })
(env-sigs [{ "key": "bob-key", "caps": [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.TRANSFER "bob" "m" 0.000001)] }])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.transfer-create "bob" "m" (read-keyset 'm) 0.000001)
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "Rsub" 0.0000007 (time "2026-06-01T00:00:00Z"))
(let* ((subs ["alice" "y" "x" "bob" "m"])
       (owed-each (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) subs))
       (sum-floor (fold (+) 0.0 (map (lambda (v:decimal) (floor v 12)) owed-each)))
       (floor-sum (floor (fold (+) 0.0 owed-each) 12)))
  (print (format "V18 SUB-ADIT owed-m={} Sfloor={} floorS={}" [(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of "m") sum-floor floor-sum]))
  (expect "V18 Sfloor(owed_i) <= floor(Sowed_i) (fraccionar no gana)" true (<= sum-floor floor-sum)))
(commit-tx)
(print "V18 FIN")
