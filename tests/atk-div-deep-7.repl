;; V7 — DOBLE APPLY-ROUND (idempotencia): rate normal, apply dos veces; rps no debe inflarse.
(load "setup.repl")
(load "seed-div.repl")
(env-data { "accts": ["alice" "bob"] })
(begin-tx "V7 declare R1 0.02")
(env-keys ["admin-key"])
(n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.declare-round "R1" 0.02 (time "2026-06-01T00:00:00Z"))
(commit-tx)
(begin-tx "V7 apply dos veces")
(env-keys ["admin-key"])
(let ((rps-before (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
  (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.apply-round "a1")
  (expect-failure "V7 segundo apply es no-op" "no newly-effective rounds to apply"
    (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.apply-round "a2"))
  (expect "V7 rps sin inflar" rps-before (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.get-rps)))
(let ((o1 (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.dividend-liability))
      (on (fold (+) 0.0 (map (lambda (a:string) (n_d97ffd2ca290429b5dc85ce551a8d07d038e9641.smartpacts-shares.pending-dividends-of a)) (read-msg 'accts)))))
  (print (format "V7 ORACULO: O1={} On={}" [o1 on]))
  (expect "V7 O1==On tras doble apply" on o1)
  (expect "V7 L == 5000*0.02 = 100" 100.0 o1))
(commit-tx)
(print "V7 FIN")
